{
  "name": "local-model-inference",
  "version": "0.1.0",
  "description": "Desktop app for running AI model inference locally via Ollama",
  "main": "./out/main/index.js",
  "author": "Zachary Yu",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.zacharyyu.localinference",
    "productName": "Local Inference",
    "files": ["out/**/*"],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Fractal-Machine-Research",
      "repo": "local-model-inference"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
